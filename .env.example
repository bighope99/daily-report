# hybrid_logger 設定ファイル
# このファイルを .env にコピーして使用してください
# cp .env.example .env

# ログ保存先ディレクトリ（Google Drive等の共有フォルダを指定すると複数PCで共有可能）
# Windows 例: DAILY_REPORT_LOG_DIR=G:\マイドライブ\50_個人\日報用
# Mac 例:     DAILY_REPORT_LOG_DIR=/Users/yourname/Google Drive/マイドライブ/50_個人/日報用
DAILY_REPORT_LOG_DIR=

# Tesseract 実行ファイルのパス（デフォルトから変えたい場合のみ設定）
# Windows デフォルト: C:\Program Files\Tesseract-OCR\tesseract.exe
# Mac デフォルト: tesseract（brew install tesseract でPATHに入る）
TESSERACT_CMD=
